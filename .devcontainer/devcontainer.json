{
  "name": "PyConLT2026 Talk",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "workspaceFolder": "/workspaces/PyConLT2026",
  "customizations": {
    "vscode": {
      "extensions": [
        "davidanson.vscode-markdownlint",
				"ms-python.python",
				"ms-python.vscode-pylance",
				"ms-toolsai.jupyter",
				"mongodb.mongodb-vscode",
				"marp-team.marp-vscode",
				"bpruitt-goddard.mermaid-markdown-syntax-highlighting",
				"charliermarsh.ruff"
      ],
      "settings": {
        "markdown.preview.breaks": true,
        "markdownlint.config": {
          "default": true,
          "MD013": false,
          "MD025": false,
          "MD033": false,
          "MD041": false
        },
        "python.defaultInterpreterPath": "/usr/bin/python"
      }
    }
  },
  "postCreateCommand": "pip install -r requirements.txt && markdownlint --config .markdownlint.json slides.md && marp --version && marp slides.md --allow-local-files --html --output /workspaces/PyConLT2026/slides.html",
  "remoteUser": "vscode"
}